{
  "name": "clarity",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Clarity",
  "description": "Clarity — AI-powered writing assistant for product managers. Structured templates, real-time coaching, and AI-powered feedback.",
  "scripts": {
    "dev": "vite --port 5181",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite --port 5181 --strictPort\" \"wait-on tcp:127.0.0.1:5181 && electron .\"",
    "electron:build": "vite build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.6.0",
    "firebase": "^12.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "docx": "^9.6.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "file-saver": "^2.0.5",
    "globals": "^16.5.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "wait-on": "^8.0.0"
  }
}
